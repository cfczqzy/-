pipeline {
    agent any

    environment {
        KUBE_NS   = 'default'
        APP_NAME  = 'myapp'
        IMAGE_TAG = "${BUILD_NUMBER}"
        REGISTRY  = 'myrepo/myapp'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('初始化：识别当前环境') {
            steps {
                script {
                    def curEnv = sh(
                        script: "kubectl get svc ${APP_NAME}-svc -n ${KUBE_NS} -o jsonpath='{.spec.selector.version}'",
                        returnStdout: true
                    ).trim()

                    if (curEnv != 'blue' && curEnv != 'green') {
                        error("无法识别当前环境：${curEnv}")
                    }

                    env.CURRENT_ENV = curEnv
                    env.TARGET_ENV  = (curEnv == 'blue') ? 'green' : 'blue'

                    echo "当前活跃环境：${env.CURRENT_ENV}"
                    echo "目标部署环境：${env.TARGET_ENV}"
                }
            }
        }

        stage('构建 & 推送镜像') {
            steps {
                sh '''
                    docker build -t ${REGISTRY}:${IMAGE_TAG} .
                    docker push ${REGISTRY}:${IMAGE_TAG}
                '''
            }
        }

        stage('部署新版本到 Standby') {
            steps {
                sh '''
                    sed "s|IMAGE_PLACEHOLDER|${REGISTRY}:${IMAGE_TAG}|g" \
                        k8s/deployment-${TARGET_ENV}.yaml > k8s/deployment-${TARGET_ENV}-tmp.yaml

                    kubectl apply -n ${KUBE_NS} -f k8s/deployment-${TARGET_ENV}-tmp.yaml
                    kubectl rollout status deployment/${APP_NAME}-${TARGET_ENV} -n ${KUBE_NS} --timeout=180s
                '''
            }
        }

        stage('健康检查（Standby）') {
            steps {
                sh '''
                    POD=$(kubectl get pods -n ${KUBE_NS} -l app=${APP_NAME},version=${TARGET_ENV} -o jsonpath='{.items[0].metadata.name}')
                    kubectl exec $POD -n ${KUBE_NS} -- curl -sf http://localhost:8080/health || exit 1
                '''
            }
        }

        stage('人工审批：切流') {
            steps {
                input message: "确认将流量切换到 ${TARGET_ENV}？", ok: '确认切换'
            }
        }

        stage('切换流量（蓝绿切换）') {
            steps {
                sh '''
                    kubectl patch svc ${APP_NAME}-svc -n ${KUBE_NS} \
                      -p '{"spec":{"selector":{"app":"${APP_NAME}","version":"${TARGET_ENV}"}}}'
                '''
                echo "✅ 流量已切换至 ${TARGET_ENV}"
            }
        }

        stage('清理旧环境（可选）') {
            steps {
                input message: "是否缩容旧环境 ${CURRENT_ENV} 到 0？", ok: '缩容'
                sh '''
                    kubectl scale deployment ${APP_NAME}-${CURRENT_ENV} -n ${KUBE_NS} --replicas=0
                '''
            }
        }
    }

    post {
        failure {
            script {
                echo "❌ 发布失败，尝试回滚流量..."
                sh '''
                    kubectl patch svc ${APP_NAME}-svc -n ${KUBE_NS} \
                      -p '{"spec":{"selector":{"app":"${APP_NAME}","version":"${CURRENT_ENV}"}}}'
                '''
                echo "✅ 流量已回滚至 ${CURRENT_ENV}"
            }
        }
        always {
            cleanWs()
        }
    }
}